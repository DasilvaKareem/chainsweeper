# ElevenLabs API key — dev-only, used by `pnpm gen:audio` to regenerate game audio.
# This is NOT shipped with the game. Audio files are pre-generated into public/assets/audio/.
ELEVENLABS_API_KEY=

# Cloudflare Worker URL for multiplayer Durable Object rooms.
# Local wrangler dev: ws://localhost:8787
# Deployed: wss://chainsweeper-room.<account>.workers.dev
VITE_WORKER_URL=ws://localhost:8787

# SKALE BITE V2 Sandbox 2 RPC URL (chain id 1036987955).
# Access is gated — request via SKALE Discord. Fill in once provisioned.
VITE_SKALE_RPC_URL=

# Deployed on-chain contract addresses. Set after `forge create`.
VITE_MATCH_CONTRACT=
VITE_RATINGS_CONTRACT=

# Territories mode contracts (MachineSweepPlots / Repairs / Marketplace).
VITE_PLOTS_CONTRACT=
VITE_REPAIRS_CONTRACT=
VITE_MARKETPLACE_CONTRACT=
